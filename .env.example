# Mind2Dialogue — environment variables (rename to .env and fill in)
# All entry scripts read these; .env is gitignored.

# OpenAI-compatible LLM endpoint. Works with vLLM, OpenAI, Anthropic-via-gateway, …
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=sk-...

# Default model name on the endpoint above. Used when the per-role
# overrides (SIM_MODEL / ORACLE_MODEL / JUDGE_MODEL) are not set.
MODEL_NAME=gpt-4o-mini

# Optional per-role overrides. Splitting roles across endpoints is the
# recommended way to avoid self-judging bias and to use a stronger judge.
# SIM_MODEL=gpt-4o-mini
# ORACLE_MODEL=gpt-4o
# JUDGE_MODEL=gpt-4.1-mini
